---
layout: null
permalink: /feed.xml
---
{%- comment -%}
  Combined Atom feed across all output:true collections, sorted by date desc.
  Extend by adding `| concat: site.<collection>` below.
{%- endcomment -%}
{%- assign _entries = site.publications | concat: site.preprints | concat: site.talks | sort: "date" | reverse -%}
{%- assign _latest = _entries | first -%}
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title }}</title>
  <subtitle>{{ site.description }}</subtitle>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self"/>
  <link href="{{ '/' | absolute_url }}"/>
  <updated>{% if _latest %}{{ _latest.date | date_to_xmlschema }}{% else %}{{ site.time | date_to_xmlschema }}{% endif %}</updated>
  <id>{{ '/' | absolute_url }}</id>
  <author>
    <name>{{ site.data.profile.name.full }}</name>
    <email>{{ site.data.profile.email }}</email>
  </author>
  {% for entry in _entries limit: 30 %}
  <entry>
    <title>{{ entry.title | xml_escape }}</title>
    <link href="{{ entry.url | absolute_url }}"/>
    <id>{{ entry.url | absolute_url }}</id>
    <updated>{{ entry.date | date_to_xmlschema }}</updated>
    <published>{{ entry.date | date_to_xmlschema }}</published>
    <category term="{{ entry.collection }}"/>
    {% if entry.description %}<summary>{{ entry.description | xml_escape }}</summary>{% elsif entry.venue %}<summary>{{ entry.title | xml_escape }} — {{ entry.venue | xml_escape }}</summary>{% endif %}
    <content type="html">{{ entry.content | xml_escape }}</content>
  </entry>
  {% endfor %}
</feed>
